  *{
    padding: 0px;
    margin: 0px;
    box-sizing: border-box;
  }
  body{
    width: 100vw;
    height: 100vh;
     font-family: "Lexend Deca", sans-serif;
     display: flex;
     flex-direction: column;
     align-items: center;
     justify-content: center;
  }
  .main{
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    border: 2px solid white;
    padding: 50px 50px;
    border-radius: 10px;
    background:linear-gradient(#62cff4,#2c67f2);
    color:white
  }
  input{
    padding: 5px 20px;
    border-radius: 5px;
      outline: none;
     border: 1px solid white;
  }
  .main-container
  {
    width: 100%;  
    display:flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  button{
    padding: 5px 10px;
     border-radius: 5px;
     outline: none;
     border: none;
     cursor: pointer;
     font-weight: 600;
     background-color: #62cff4;
  }
  .contain-1{
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 200px;
    height: 200px;
    border:2px solid white;
    border-radius:100%;
    margin-top: 10px;
    gap:1rem; 
  }
  h1{
    font-size: 35px;
    font-weight: 600;
  }
  h2{
    font-size: 15px;
  }
  .wind{
    width: 100%;
    display: flex;
    justify-content: space-between;
    margin: 20px 0px;
    align-items: center;
  }
  label{  
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;  
    gap: 10px;
  }
  .fa-solid{
    width: 100%;
    font-size: 25px;
  }
